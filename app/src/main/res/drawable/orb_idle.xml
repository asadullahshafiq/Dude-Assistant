<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#335C6BC0" />
            <size android:width="130dp" android:height="130dp" />
        </shape>
    </item>
    <!-- Mid ring -->
    <item android:bottom="8dp" android:left="8dp" android:right="8dp" android:top="8dp">
        <shape android:shape="oval">
            <solid android:color="#665C6BC0" />
        </shape>
    </item>
    <!-- Core -->
    <item android:bottom="18dp" android:left="18dp" android:right="18dp" android:top="18dp">
        <shape android:shape="oval">
            <solid android:color="#5C6BC0" />
        </shape>
    </item>
</layer-list>
